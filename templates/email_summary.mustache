{{!
    @template   mod_syllabus/email_summary
    @copyright  Marty Gilbert <martygilbert@gmail>

    Template for sending an admin summary of courses missing syllabi

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Example context (json):
    {
        "datestr": "May 22, 2024",
        "categories": [
            {
                "catname": "Category 1",
                "withsyllabus": 5,
                "withoutsyllabus": 3,
                "courses": [
                    {
                        "name": "Course 1",
                        "url": "http://example.com/course/view.php?id=1",
                        "teachernames": "John Doe, Jane Smith"
                    }
                ]
            }
        ]
    }
}}
<p>{{#str}}summaryemailintro, mod_syllabus, {{datestr}}{{/str}}</p>

{{#categories}}
<h3>{{catname}}</h3>
<p>{{#str}}summaryemailwith, mod_syllabus{{/str}}: {{withsyllabus}} | {{#str}}summaryemailwithout, mod_syllabus{{/str}}: {{withoutsyllabus}}</p>
{{#courses}}
<p>
    <strong><a href="{{url}}">{{name}}</a></strong><br>
    {{#str}}summaryemailteachers, mod_syllabus{{/str}}: {{teachernames}}
</p>
{{/courses}}
{{^courses}}<p>{{#str}}summaryemailnocourses, mod_syllabus{{/str}}</p>{{/courses}}
{{/categories}}
